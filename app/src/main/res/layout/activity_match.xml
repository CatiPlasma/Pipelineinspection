<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 中间的左右两列区域：高度约为屏幕的 50%，整体垂直居中 -->
    <!-- 中间竖直方向的两块区域（上：目标管线；下：监控画面） -->
    <LinearLayout
        android:id="@+id/layout_column"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintHeight_default="percent"
        app:layout_constraintHeight_percent="0.8">

        <!-- 上块：目标管线区域 -->
        <LinearLayout
            android:id="@+id/layout_target"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- 标题：目标管线 -->
            <TextView
                android:id="@+id/tv_target_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="目标管线"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp" />

            <!-- 目标图片区域：占这一块的大部分高度，整体上大约接近屏幕的 1/3 -->
            <ImageView
                android:id="@+id/iv_target"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:background="@drawable/match_image_placeholder" />

            <!-- 按钮：小按钮，居中，离图片有一定间隔 -->
            <Button
                android:id="@+id/btn_select_target"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:text="选择目标管线"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>

        <!-- 下块：监控画面区域 -->
        <LinearLayout
            android:id="@+id/layout_monitor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- 标题：监控画面 -->
            <TextView
                android:id="@+id/tv_monitor_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="监控画面"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp" />

            <!-- 监控图片区域 -->
            <ImageView
                android:id="@+id/iv_monitor"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:background="@drawable/match_image_placeholder" />

            <!-- 按钮：开始匹配 -->
            <Button
                android:id="@+id/btn_start_match"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:text="开始匹配"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>

    </LinearLayout>

    <!-- 底部：匹配结果提示 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="匹配成功"
        android:textSize="16sp"
        android:textColor="#4CAF50"
        android:visibility="gone"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>